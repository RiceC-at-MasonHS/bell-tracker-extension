{
  "manifest_version": 3,
  "name": "SmartPass Bell Badge Tracker",
  "version": "1.0",
  "description": "Displays remaining period minutes directly on the extension icon.",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://smartpass.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "View Full Schedule"
  }
}